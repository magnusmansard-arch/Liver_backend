# Copy this file to .env and fill in real values. Never commit .env itself.

# Postgres connection string (e.g. from Neon, Supabase, or Railway)
DATABASE_URL="postgresql://user:password@host:5432/liver_department?schema=public"

# Long random string used to sign login tokens — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-string"

# How long a login session stays valid before re-entering the PIN
JWT_EXPIRES_IN="12h"

PORT=4000
